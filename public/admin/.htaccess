# MR. WORKOUT | SERVER DIRECTIVE
# Force PHP handling and direct rendering for Hostinger/LiteSpeed

<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>

DirectoryIndex index.php

# Protect sensitive data
<FilesMatch "\.(csv|log)$">
    Order deny,allow
    Deny from all
</FilesMatch>
