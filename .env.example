# ─────────────────────────────────────────────────────────────
# Mr. Workout — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local or any file with real secrets.
# ─────────────────────────────────────────────────────────────

# Supabase (get from: supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# NextAuth (generate secret: openssl rand -base64 32)
NEXTAUTH_URL=https://mrworkout.vercel.app
NEXTAUTH_SECRET=your_nextauth_secret_here

# Google OAuth (get from: console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OpenAI (get from: platform.openai.com → API Keys)
OPENAI_API_KEY=your_openai_key_here

# Anthropic (get from: console.anthropic.com → API Keys) — fallback if no OpenAI key
ANTHROPIC_API_KEY=your_anthropic_key_here

# ElevenLabs (get from: elevenlabs.io → Profile → API Keys)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Stripe (get from: dashboard.stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Resend — transactional email (get from: resend.com → API Keys)
RESEND_API_KEY=your_resend_key_here

# Hostinger SMTP — email sending
HOSTINGER_SMTP_USER=coach@mrworkout.pro
HOSTINGER_SMTP_PASS=your_smtp_password_here
