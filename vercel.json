{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/dashboard-alpha", "destination": "/dashboard-alpha.html" },
    { "source": "/upload", "destination": "/upload.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/followup",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/drip",
      "schedule": "0 8 * * *"
    }
  ]
}
